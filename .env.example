# Firebase Web App config — Firebase console → Project settings → General → Your apps → Web app
# GATSBY_-prefixed vars are inlined into the browser bundle at build time.

# Firebase Web API key (public, safe to expose client-side)
GATSBY_FIREBASE_API_KEY=

# Auth domain used for Firebase Authentication (e.g. your-project.firebaseapp.com)
GATSBY_FIREBASE_AUTH_DOMAIN=

# Firebase project ID
GATSBY_FIREBASE_PROJECT_ID=

# Cloud Storage bucket (not used by the chat feature, included for completeness)
GATSBY_FIREBASE_STORAGE_BUCKET=

# Firebase Cloud Messaging sender ID (unused by the chat feature)
GATSBY_FIREBASE_MESSAGING_SENDER_ID=

# Firebase Web App ID
GATSBY_FIREBASE_APP_ID=
