# GitHub API (para fetch-issues.js)
# Obtenha em: https://github.com/settings/tokens
# Permissões necessárias: repo (acesso total a repositórios)
GITHUB_TOKEN=seu_personal_access_token_aqui
GITHUB_REPO=ggdaltoso/ggdaltoso.github.io

# GitHub OAuth App (para autenticação de usuários nos comentários)
# Crie uma OAuth App em: https://github.com/settings/developers
# IMPORTANTE: Use o Client ID e Client Secret, NÃO o Personal Access Token
GITHUB_ID=seu_github_oauth_client_id
GITHUB_SECRET=seu_github_oauth_client_secret

# NextAuth
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=sua_secret_key_aleatoria
NEXTAUTH_URL=http://localhost:3000

# Variáveis públicas (disponíveis no cliente)
NEXT_PUBLIC_GITHUB_REPO=ggdaltoso/ggdaltoso.github.io
