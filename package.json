    "react-dom": "^18.3.1",
    "react-i18next": "^12.3.1",
    "react-medium-image-zoom": "^5.4.1",
    "sass": "^1.97.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "eslint": "9.39.2",
    "eslint-plugin-import": "2.32.0",
