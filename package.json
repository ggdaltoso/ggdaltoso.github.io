{
  "version": "3.0.0",
  "name": "blog-do-gg",
  "description": "Blog pessoal do Gabriel Daltoso",
  "main": "n/a",
  "scripts": {
    "develop": "npm run clean && gatsby develop",
    "build": "npm run clean && gatsby build",
    "deploy": "npm run clean && gatsby build --prefix-paths && gh-pages -d public -b master",
    "clean": "rimraf .cache public",
    "clean:posts": "rimraf ./content/posts/*",
    "generate:posts": "npm run clean:posts && node scripts/fetch-issues.js",
    "lint": "eslint --cache --ext .js,.jsx .",
    "test": "jest --config ./jest/jest-config.js",
    "test:coverage": "jest --coverage --config ./jest/jest-config.js",
    "test:watch": "jest --watch --config ./jest/jest-config.js",
    "release": "standard-version"
  },
  "repository": "https://github.com/ggdaltoso/ggdaltoso.github.io",
  "author": "Gabriel Daltoso <ggdaltoso@gmail.com>",
  "license": "MIT",
  "keywords": [
    "gatsby",
    "graphql",
    "categories",
    "static",
    "blog",
    "minimal",
    "react"
  ],
  "dependencies": {
    "@babel/runtime": "^7.28.4",
    "@react95/core": "^9.6.2",
    "@react95/icons": "^2.2.0",
    "classnames": "^2.5.1",
    "gatsby": "^5.15.0",
    "gatsby-link": "^5.15.0",
    "gatsby-plugin-catch-links": "^5.15.0",
    "gatsby-plugin-feed": "^5.15.0",
    "gatsby-plugin-google-gtag": "^5.15.0",
    "gatsby-plugin-manifest": "^5.15.0",
    "gatsby-plugin-offline": "^6.15.0",
    "gatsby-plugin-react-helmet": "^6.15.0",
    "gatsby-plugin-sass": "^6.15.0",
    "gatsby-plugin-sharp": "^5.15.0",
    "gatsby-plugin-sitemap": "^6.15.0",
    "gatsby-plugin-twitter": "^5.15.0",
    "gatsby-remark-autolink-headers": "^6.15.0",
    "gatsby-remark-copy-linked-files": "^6.15.0",
    "gatsby-remark-images": "^7.15.0",
    "gatsby-remark-prismjs": "^7.15.0",
    "gatsby-remark-relative-images": "^2.0.5",
    "gatsby-remark-responsive-iframe": "^6.15.0",
    "gatsby-remark-smartypants": "^6.15.0",
    "gatsby-source-filesystem": "^5.15.0",
    "gatsby-transformer-remark": "^6.15.0",
    "gatsby-transformer-sharp": "^5.15.0",
    "gray-matter": "^4.0.3",
    "html-react-parser": "^5.2.11",
    "invariant": "^2.2.4",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "prism-react-renderer": "^2.4.1",
    "prismjs": "^1.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet": "^6.1.0",
    "sass": "^1.97.0"
  },
  "devDependencies": {
    "@babel/core": "7.28.5",
    "@babel/plugin-proposal-class-properties": "7.18.6",
    "@babel/plugin-proposal-optional-chaining": "7.21.0",
    "@babel/plugin-transform-runtime": "^7.28.5",
    "@babel/preset-env": "7.28.5",
    "@babel/preset-react": "7.28.5",
    "autoprefixer": "10.4.23",
    "babel-core": "7.0.0-bridge.0",
