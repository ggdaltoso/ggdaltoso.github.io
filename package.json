    "jest": "30.2.0",
    "jest-cli": "30.2.0",
    "lost": "9.0.2",
    "postcss-pxtorem": "6.1.0",
    "react-test-renderer": "^18.3.1",
    "rimraf": "6.1.2",
    "standard-version": "9.5.0"
  }
}